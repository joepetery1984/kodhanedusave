    <script>
        // Tailwind script
        function initializeTailwind() {
            // Already using CDN
        }

        // Main Calculation Function
        function calculateResult() {
            const target = parseFloat(document.getElementById('targetAmount').value) || 4500000;
            const years = parseInt(document.getElementById('years').value);

            // Parameters
            const treeCost = 100000;
            const profitPerTreePerCycle = 13500;
            const cyclesPerYear = 4;
            const daysPerYear = 365;

            let dailySavings = 8500; // starting guess
            let bestDaily = 0;
            let finalTrees = 0;
            let finalValue = 0;
            let totalProfitEarned = 0;

            // Binary search to find required daily savings
            let low = 1000;
            let high = 50000;

            let daysPerCycle = daysPerYear / cyclesPerYear;

            for (let iter = 0; iter < 25; iter++) {
                dailySavings = Math.floor((low + high) / 2);

                let trees = 0;
                let cash = 0;
                let profitEarned = 0;

                for (let c = 0; c < years * cyclesPerYear; c++) {
                    // 1. Tambahkan setoran harian yang dikumpulkan selama 1 siklus
                    cash += dailySavings * daysPerCycle;
                    
                    // 2. Pohon yang ada menghasilkan profit
                    let cycleProfit = trees * profitPerTreePerCycle;
                    profitEarned += cycleProfit;
                    cash += cycleProfit; // Profit masuk ke saldo cash!

                    // 3. Beli pohon baru dari saldo cash yang ada
                    let newTrees = Math.floor(cash / treeCost);
                    trees += newTrees;
                    cash -= newTrees * treeCost;
                }

                finalValue = trees * treeCost + cash;

                if (finalValue >= target) {
                    high = dailySavings;
                    bestDaily = dailySavings;
                    finalTrees = trees;
                    totalProfitEarned = profitEarned;
                } else {
                    low = dailySavings;
                }
            }

            // --- Generate Detailed Table Data ---
            let simTrees = 0;
            let simCash = 0;
            let tableHTML = '';
            
            for (let y = 1; y <= years; y++) {
                let yearlySavings = 0;
                let yearlyProfit = 0;
                
                for (let c = 0; c < cyclesPerYear; c++) {
                    let cycleSavings = bestDaily * daysPerCycle;
                    simCash += cycleSavings;
                    yearlySavings += cycleSavings;
                    
                    let cycleProfit = simTrees * profitPerTreePerCycle;
                    yearlyProfit += cycleProfit;
                    simCash += cycleProfit;
                    
                    let newTrees = Math.floor(simCash / treeCost);
                    simTrees += newTrees;
                    simCash -= newTrees * treeCost;
                }
                
                let endOfYearValue = (simTrees * treeCost) + simCash;
                
                tableHTML += `
                    <tr class="bg-white hover:bg-green-50 transition duration-150">
                        <td class="px-5 py-4 font-semibold text-gray-900">${y}</td>
                        <td class="px-5 py-4 text-gray-600">Rp ${Math.round(yearlySavings).toLocaleString('id-ID')}</td>
                        <td class="px-5 py-4 text-gray-800 font-medium">${simTrees} <i class="fa-solid fa-tree text-green-600 text-xs ml-1"></i></td>
                        <td class="px-5 py-4 text-green-600 font-semibold">+Rp ${Math.round(yearlyProfit).toLocaleString('id-ID')}</td>
                        <td class="px-5 py-4 font-bold text-gray-900">Rp ${Math.round(endOfYearValue).toLocaleString('id-ID')}</td>
                    </tr>
                `;
            }

            document.getElementById('projectionTableBody').innerHTML = tableHTML;
            document.getElementById('tableContainer').classList.remove('hidden');

            // --- Update UI with Animations ---
            const resultBox = document.getElementById('resultBox');
            resultBox.classList.remove('result-highlight');
            void resultBox.offsetWidth; // Trigger reflow for animation restart
            resultBox.classList.add('result-highlight');

            document.getElementById('dailySavings').innerHTML = 'Rp ' + Math.round(bestDaily).toLocaleString('id-ID');
            document.getElementById('finalTrees').innerHTML = finalTrees.toLocaleString('id-ID');
            
            // Format lebih presisi (menggunakan nilai asli, bukan 'jt')
            document.getElementById('totalProfit').innerHTML = 'Rp ' + Math.round(totalProfitEarned).toLocaleString('id-ID');
            document.getElementById('finalValue').innerHTML = 'Rp ' + Math.round(finalValue).toLocaleString('id-ID');
        }

        function selectProgram(target, years) {
            setTarget(target);
            document.getElementById('yearsSlider').value = years;
            handleYearSlider(document.getElementById('yearsSlider'));

            // Scroll to calculator
            document.getElementById('calculator').scrollIntoView({ behavior: 'smooth' });
        }

        function scrollToCalculator() {
            document.getElementById('calculator').scrollIntoView({ behavior: 'smooth' });
        }

        function showHowItWorks() {
            alert("Fitur 'Cara Kerja' akan ditambahkan di versi berikutnya. Terima kasih!");
        }

        function contactUs() {
            window.location.href = "https://wa.me/6285113128011?text=Halo%20Kodhan%2C%20saya%20ingin%20tanya%20tentang%20program%20Edusave";
        }



        function handleTargetInput(input) {
            // Remove non-numeric chars
            let value = input.value.replace(/[^0-9]/g, '');
            if (!value) value = '0';
            
            // Parse to int
            let num = parseInt(value, 10);
            
            // Update hidden input
            document.getElementById('targetAmount').value = num;
            
            // Format and update display
            input.value = num.toLocaleString('id-ID');
            
            calculateResult();
        }

        function setTarget(amount) {
            document.getElementById('targetAmount').value = amount;
            document.getElementById('targetAmountDisplay').value = amount.toLocaleString('id-ID');
            calculateResult();
        }

        function handleYearSlider(slider) {
            let val = slider.value;
            document.getElementById('years').value = val;
            
            let label = val + ' Tahun';
            if(val == 1) label += ' (Daftar Ulang)';
            else if(val == 2) label += ' (SMP)';
            else if(val == 3) label += ' (SMA)';
            else if(val == 6) label += ' (S1)';
            else if(val == 9) label += ' (S2)';
            
            document.getElementById('yearLabel').innerText = label;
            calculateResult();
        }

        // Initialize
        window.onload = function () {
            initializeTailwind();

            // Run initial calculation
            setTimeout(() => {
                calculateResult();
            }, 300);

            // Add enter key support
            document.getElementById('targetAmountDisplay').addEventListener('keypress', function (e) {
                if (e.key === 'Enter') calculateResult();
            });
        }

        // Keyboard shortcut
        document.addEventListener('keydown', function (e) {
            if (e.metaKey && e.key === "/") {
                e.preventDefault();
                document.getElementById('targetAmountDisplay').focus();
            }
        });
    </script>
